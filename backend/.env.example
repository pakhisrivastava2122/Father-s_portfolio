# Port the server runs on (most hosts like Render/Railway set this automatically)
PORT=5000

# Secret token YOU choose, used to view submitted leads at /api/leads
# Change this to something only you know before deploying.
ADMIN_TOKEN=change-this-to-a-secret-value

# OPTIONAL: Email notification settings.
# If you fill these in, the server will email a notification to
# durgeshsrivastavalic@gmail.com every time someone submits the contact form.
# Leave blank to skip email notifications (leads are still saved and viewable via /api/leads).
#
# For Gmail: turn on 2-Step Verification on the Google account, then create an
# "App Password" (Google Account > Security > App passwords) and use that here -
# NOT the normal Gmail password.
EMAIL_USER=
EMAIL_APP_PASSWORD=
NOTIFY_EMAIL=durgeshsrivastavalic@gmail.com
